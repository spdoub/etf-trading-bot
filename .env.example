# Groq API (sentiment + monthly review)
GROQ_API_KEY=your_groq_api_key_here
# Default: meta-llama/llama-4-scout-17b-16e-instruct (30K TPM). For llama-3.3-70b-versatile (12K TPM):
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_INPUT_TOKEN_BUDGET=9500
# GROQ_SENTIMENT_MAX_DATA_CHARS=26000
# GROQ_REVIEW_INPUT_TOKEN_BUDGET=9500
# GROQ_REVIEW_MAX_PROMPT_CHARS=28000

# Alpaca trading
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_PAPER=true
# ALPACA_BASE_URL=                   # optional override; auto-set from ALPACA_PAPER

# Telegram (daily reports)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Data source keys (all optional — core feeds are free/keyless)
SAM_GOV_API_KEY=your_sam_gov_api_key_here
USAJOBS_API_KEY=your_usajobs_api_key_here
USAJOBS_EMAIL=your_email@example.com

# General
LOG_LEVEL=INFO
DB_PATH=data/etf_bot.db

# Railway / Docker (persistent SQLite on a mounted volume)
# DB_PATH=/data/etf_bot.db
# SCHEDULE_UTC_TIME=13:35
# ENABLE_SCHEDULER=true
# PORT=8501
